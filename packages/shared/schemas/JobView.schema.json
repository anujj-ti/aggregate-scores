{
  "$ref": "#/definitions/JobView",
  "definitions": {
    "JobView": {
      "type": "object",
      "properties": {
        "jobId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "GENERATING",
            "PENDING",
            "RUNNING",
            "COMPLETE",
            "FAILED",
            "CANCELLED"
          ]
        },
        "F": {
          "type": "integer",
          "minimum": 1
        },
        "C": {
          "type": "integer",
          "minimum": 1
        },
        "reuseSampleFile": {
          "type": "boolean"
        },
        "submittedAt": {
          "type": "integer",
          "minimum": 0
        },
        "endedAt": {
          "type": "integer",
          "minimum": 0
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reductionsRemaining": {
          "type": "integer",
          "minimum": 0
        },
        "queuePosition": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "chunkSizeUsed": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "leafTasksTotal": {
          "type": "integer",
          "minimum": 0
        },
        "leafTasksDone": {
          "type": "integer",
          "minimum": 0
        },
        "readyCount": {
          "type": "integer",
          "minimum": 0
        },
        "claimedCount": {
          "type": "integer",
          "minimum": 0
        },
        "taskSummary": {
          "type": "object",
          "properties": {
            "queued": {
              "type": "integer",
              "minimum": 0
            },
            "inProgress": {
              "type": "integer",
              "minimum": 0
            },
            "done": {
              "type": "integer",
              "minimum": 0
            },
            "failed": {
              "type": "integer",
              "minimum": 0
            },
            "total": {
              "type": "integer",
              "minimum": 0
            },
            "byLevel": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "level": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "queued": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "inProgress": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "done": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "failed": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "total": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "required": [
                  "level",
                  "queued",
                  "inProgress",
                  "done",
                  "failed",
                  "total"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "queued",
            "inProgress",
            "done",
            "failed",
            "total",
            "byLevel"
          ],
          "additionalProperties": false
        },
        "inputManifestPreview": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "fileIndex": {
                "type": "integer",
                "minimum": 0
              },
              "inputKey": {
                "type": "string",
                "minLength": 1
              },
              "plannedLeafTaskId": {
                "type": "string",
                "minLength": 1
              },
              "plannedLeafLevel": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "fileIndex",
              "inputKey",
              "plannedLeafTaskId",
              "plannedLeafLevel"
            ],
            "additionalProperties": false
          }
        },
        "resultUrl": {
          "type": "string",
          "format": "uri"
        },
        "error": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "jobId",
        "status",
        "F",
        "C",
        "submittedAt",
        "percent",
        "reductionsRemaining"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
