{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "out/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "format:check": {},
    "build:schemas": {
      "dependsOn": ["^build:schemas"],
      "outputs": ["schemas/**"]
    },
    "gen:contracts": {
      "dependsOn": ["build:schemas"],
      "outputs": ["src/worker/contracts.py"]
    }
  }
}
